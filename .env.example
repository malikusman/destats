# Base URL for the scorpius-netapp-ingestion-api.
#
# In dev this defaults to /api-proxy, which the Vite dev server proxies to
# http://10.0.65.40:8080 (see vite.config.ts). In the Docker container, Nginx
# proxies the same /api-proxy prefix (see nginx.conf.template / API_TARGET).
#
# Point it at a direct URL only if the browser can reach the API host and the
# API allows cross-origin requests.
VITE_API_BASE_URL=/api-proxy
